# BenchLens environment template
# Copy to .env and fill in real values. Do NOT commit .env.

# ---------- Application ----------
APP_ENV=development              # development | staging | production
APP_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR

# ---------- PostgreSQL warehouse ----------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=benchlens
POSTGRES_USER=benchlens
POSTGRES_PASSWORD=change_me_in_real_env
POSTGRES_SCHEMA=public

# ---------- REST API (Day 6) ----------
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=2
JWT_SECRET=change_me_to_a_long_random_string
JWT_ALGORITHM=HS256
JWT_EXPIRES_MINUTES=60

# ---------- Alerts (Day 9) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_FROM=benchlens@example.com
ALERT_EMAIL_TO=team@example.com
TEAMS_WEBHOOK_URL=

# ---------- Power BI deploy (Day 9) ----------
POWERBI_TENANT_ID=
POWERBI_CLIENT_ID=
POWERBI_CLIENT_SECRET=
POWERBI_WORKSPACE_ID=
